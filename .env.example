# afocat-migrate — variables de entorno
# Copiar a .env (gitignored) y completar. NUNCA commitear .env con secretos reales.

# --- Proyecto destino ---
AFOCAT_PROJECT_ROOT=c:\xampp\htdocs\sys_Afocat
AFOCAT_PHP_BIN=c:\xampp\php\php.exe
AFOCAT_OCREND_INI=c:\xampp\htdocs\sys_Afocat\Ocrend\Kernel\Config\Ocrend.ini.yml

# --- FTP/FTPS prod (DigitalOcean) — para ftp_deploy ---
# Dejar vacios para deshabilitar deploy. El MCP exige los 3 para subir.
AFOCAT_FTP_HOST=
AFOCAT_FTP_USER=
AFOCAT_FTP_PASS=
AFOCAT_FTP_REMOTE_ROOT=/home2/afoca4w2/public_html/erp
AFOCAT_FTP_SECURE=false

# Nota: las credenciales de DB las lee el MCP directamente de AFOCAT_OCREND_INI,
# no se duplican aqui.
